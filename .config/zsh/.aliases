# shellcheck shell=bash

alias ll="ls -AlF --time-style='+%F %R' --group-directories-first"
alias la="ls -A"
alias l="ls -CF"

alias dpg="docker run -d --name postgres-dev -e POSTGRES_DB=dev -e POSTGRES_USER=postgres -e POSTGRES_PASSWORD=postgres -p 5432:5432 postgres:latest"

alias eza="EZA_ICON_SPACING=2 eza --long --all --octal-permissions --group --group-directories-first --time-style long-iso --header --icons auto"

alias diff="diff --color -u"

alias sz='. ${ZDOTDIR}/.zprofile && . ${ZDOTDIR}/.zshrc'
alias SZ='tmux-shell-cmd --kill "sz"'
alias dt='cd ${DOTFILES_PATH} && nvim .'
alias lz='cd ${XDG_DATA_HOME}/nvim/lazy/LazyVim && nvim .'
alias lp='cd ${XDG_DATA_HOME}/nvim/lazy && nvim .'

alias 755d="find . -type d -exec chmod 755 {} \;"
alias 644f="find . -type f -exec chmod 644 {} \;"

alias vss='sort -u ${XDG_CONFIG_HOME}/nvim/spell/en.utf-8.add -o ${XDG_CONFIG_HOME}/nvim/spell/en.utf-8.add'
alias vdt='rm ${XDG_STATE_HOME}/nvim/swap/%*'

# shellcheck disable=SC2139
alias pf="fzf ${FZF_CTRL_T_OPTS}"

alias gi="git init && git symbolic-ref HEAD refs/heads/main"
alias gcl="git diff --name-only --diff-filter=U"
alias gl1="git log --graph --abbrev-commit --decorate --format=format:'%C(bold blue)%h%C(reset) - %C(bold green)(%ar)%C(reset) %C(white)%s%C(reset) %C(dim white)- %an%C(reset)%C(bold yellow)%d%C(reset)' --all"
alias gl2="git log --graph --abbrev-commit --decorate --format=format:'%C(bold blue)%h%C(reset) - %C(bold cyan)%aD%C(reset) %C(bold green)(%ar)%C(reset)%C(bold yellow)%d%C(reset)%n          %C(white)%s%C(reset) %C(dim white)- %an%C(reset)' --all"

alias ge="rg '[\p{Emoji}--\p{Ascii}]'"

alias drun='docker container run --rm -it -v "${PWD}":/app -w /app'

alias k="kubectl"
alias tf="terraform"
alias ymp3="yt-dlp --embed-metadata --extract-audio --audio-format mp3"

alias jl="jupyter-lab --no-browser"

alias wget="wget --hsts-file=${XDG_CONFIG_HOME}/wget/wget-hsts"

alias addve='python -m ipykernel install --user --name'

alias act='source .venv/bin/activate'
alias dact='deactivate'

# uvx tools
alias tldr='uvx tldr'
alias hg='uvx --from mercurial hg'
alias duckdb='uvx --from duckdb-cli duckdb'
alias flake8='uvx flake8'

alias vs="code ."

# A way to define and run tasks in a project. It's like make except it's pure
# Bash so there's no make limitations like not being able to forward arguments.
alias run=./run
